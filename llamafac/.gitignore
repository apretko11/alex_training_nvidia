
# never commit local env files
LLaMA-Factory/.env.local

# never commit generated datasets
# Keep data generation scripts/metadata, but ignore generated dataset shards
LLaMA-Factory/data/*.json
!LLaMA-Factory/data/dataset_info.json
LLaMA-Factory/data/*.jsonl
LLaMA-Factory/data/*.parquet

# never commit inference stuff
LLaMA-Factory/examples/inference/

# never commit python build artifacts
**/__pycache__/
**/*.pyc
LLaMA-Factory/src/llamafactory.egg-info/

# never commit llvmir_transfer (entire folder)
llvmir_transfer/
